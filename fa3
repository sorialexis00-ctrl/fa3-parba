# Program No. 3 (fa3prog3)

# Ask for student information
name = input("Enter student's name: ")
score = float(input("Enter student's score: "))

# Determine letter grade
if 90 <= score <= 100:
    grade = "A"
elif 80 <= score <= 89:
    grade = "B"
elif 70 <= score <= 79:
    grade = "C"
else:
    grade = "F"

# Display result
print("\n--- Grading Result ---")
print(f"Name  : {name}")
print(f"Score : {score}")
print(f"Grade : {grade}")
     
